{
  "name": "@iot-billing-service/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "build": "tsc",
    "start": "node dist/api/index.js",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --check src/ tests/",
    "format:fix": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:load": "tsx tests/load/simulation_runner.ts",
    "test:load:unit": "vitest run tests/unit/load",
    "load:mock": "tsx tests/load/mock_server.ts",
    "load:steady": "tsx tests/load/simulation_runner.ts steady_state 1000 60",
    "load:burst": "tsx tests/load/simulation_runner.ts burst 1000 30",
    "load:recovery": "tsx tests/load/simulation_runner.ts recovery 1000 120",
    "load:smoke": "tsx tests/load/cli_smoke.ts",
    "k6:bundle": "tsx tests/load/k6_scripts/build.ts",
    "k6:steady": "k6 run tests/load/dist/k6/steady_state.js",
    "k6:burst": "k6 run tests/load/dist/k6/burst.js",
    "k6:recovery": "k6 run tests/load/dist/k6/recovery.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.2",
    "@opentelemetry/instrumentation-pg": "^0.51.1",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/client": "^6.6.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "async-mutex": "^0.5.0",
    "dotenv": "^16.4.7",
    "ed2curve": "^0.3.0",
    "fastify": "^5.3.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1"
  }
}
